{
  "name": "apollo",
  "version": "0.1.0",
  "description": "Pi-native skill-turn observer extension",
  "type": "module",
  "private": false,
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "extensions",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test dist/tests/*.test.js",
    "pretest": "npm run build"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^22.15.0"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "apollo"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
